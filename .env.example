# pfix Configuration

# Required: OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Model (default: openrouter/anthropic/claude-sonnet-4)
#PFIX_MODEL=openrouter/nvidia/nemotron-3-super-120b-a12b:free
#PFIX_MODEL=openrouter/qwen/qwen3-235b-a22b-2507
#PFIX_MODEL=openrouter/anthropic/claude-sonnet-4
#PFIX_MODEL=google/gemini-2.5-flash-lite
#PFIX_MODEL=openrouter/qwen/qwen3.5-flash-02-23
PFIX_MODEL=xiaomi/mimo-v2-flash

# Behavior
PFIX_AUTO_APPLY=false         # true = apply fixes without asking
PFIX_AUTO_INSTALL_DEPS=true   # true = auto pip/uv install
PFIX_AUTO_RESTART=false       # true = os.execv restart after fix
PFIX_MAX_RETRIES=3
PFIX_DRY_RUN=false
PFIX_ENABLED=true
PFIX_PKG_MANAGER=             # "pip" or "uv" (auto-detected)

# Git integration
PFIX_GIT_COMMIT=false         # true = auto-commit fixes
PFIX_GIT_PREFIX=pfix:         # commit message prefix

# MCP server
PFIX_MCP_ENABLED=false
PFIX_MCP_TRANSPORT=stdio      # "stdio" or "http"
PFIX_MCP_SERVER_URL=http://localhost:3001
